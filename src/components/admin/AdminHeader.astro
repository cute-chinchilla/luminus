---
import { UserButton } from '@clerk/astro/components';
---

<header class="h-[70px] bg-white border-b border-gray-200 flex items-center justify-between px-6 sticky top-0 z-[90]">
  <div class="flex items-center gap-4">
    <!-- Mobile Title (Hidden on Desktop since Sidebar has it) -->
    <a href="/admin" class="md:hidden font-en text-lg font-bold text-dark tracking-[3px] uppercase no-underline">
      LUMIN<span class="text-primary">U</span>S
    </a>
  </div>
  
  <div class="flex items-center gap-5">
    <a href="/" target="_blank" class="text-[13px] text-gray-500 hover:text-dark transition-colors no-underline hidden sm:flex items-center gap-1.5">
      <i class="fas fa-external-link-alt"></i> 홈페이지 가기
    </a>
    <div class="w-px h-4 bg-gray-300 hidden sm:block"></div>
    <div class="flex flex-col items-end mr-1 hidden sm:flex">
      <span class="text-[13px] font-bold text-dark leading-tight">관리자님</span>
      <span class="text-[11px] text-primary">Admin</span>
    </div>
    <UserButton appearance={{ elements: { userButtonAvatarBox: "w-9 h-9 border border-gray-200" } }} />
  </div>
</header>
