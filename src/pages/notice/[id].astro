---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getDB } from '@/lib/db';
import type { Notice } from '@/lib/types';
import { formatDate } from '@/lib/format';

const { id } = Astro.params;
const DB = getDB(Astro.locals);

const notice = await DB.prepare('SELECT * FROM notices WHERE id = ? AND is_active = 1').bind(id).first() as unknown as Notice;

if (!notice) {
  return Astro.redirect('/404');
}
---

<BaseLayout 
  title={`${notice.title} - 루미너스의원`}
  description={notice.title}
  image={notice.thumbnail_url}
  type="article"
>
  <section class="pt-40 pb-20 md:pt-48 md:pb-28 px-5 md:px-10 bg-white min-h-screen">
    <div class="max-w-[900px] mx-auto">
      <!-- Header -->
      <div class="text-center mb-10 md:mb-16">
        <span class={`inline-block px-4 py-1 text-[12px] font-bold rounded-full mb-5 ${
          notice.category === 'event' ? 'bg-primary text-dark' : 'bg-dark text-white'
        }`}>
          {notice.category === 'event' ? 'EVENT' : 'NOTICE'}
        </span>
        <h2 class="text-2xl md:text-4xl font-bold text-dark mb-6 leading-tight">
          {notice.title}
        </h2>
        <div class="text-sm text-muted flex items-center justify-center gap-4">
          <span class="flex items-center"><i class="far fa-calendar-alt mr-2"></i> {formatDate(notice.created_at)}</span>
        </div>
      </div>

      <!-- Thumbnail -->
      {notice.thumbnail_url && (
        <div class="mb-12 md:mb-16 rounded-3xl overflow-hidden shadow-xl">
          <img src={notice.thumbnail_url} alt={notice.title} class="w-full h-auto" />
        </div>
      )}

      <!-- Content -->
      <div class="prose prose-lg max-w-none text-dark leading-relaxed mb-16" set:html={notice.content} />

      <!-- Footer / Back Button -->
      <div class="border-t border-gray-100 pt-10 text-center">
        <a 
          href="/notice" 
          class="inline-flex items-center justify-center px-10 py-4 bg-dark text-white text-sm font-bold tracking-widest no-underline hover:bg-black transition-all rounded-lg"
        >
          목록으로 돌아가기
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  /* Basic prose styles for notice content */
  .prose img {
    max-width: 100%;
    height: auto;
    border-radius: 1rem;
    margin: 2rem 0;
  }
  .prose p {
    margin-bottom: 1.5rem;
  }
  .prose h1, .prose h2, .prose h3 {
    margin-top: 2.5rem;
    margin-bottom: 1.5rem;
    font-weight: 700;
  }
</style>
