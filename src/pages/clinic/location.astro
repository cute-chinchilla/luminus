---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageBanner from '@/components/common/PageBanner.astro';
import LocationSection from '@/components/home/Location.astro';
import ContactForm from '@/components/common/ContactForm';
---

<BaseLayout 
  title="오시는 길 - 루미너스의원" 
  description="송도에 위치한 루미너스의원 오시는 길과 진료 시간을 안내해 드립니다."
>
  <PageBanner 
    title_en="Location" 
    title_ko="오시는 길" 
    description="루미너스의원 오시는 길을 안내합니다"
    subtitle="" 
  />

  <div class="py-16 md:py-24">
    <!-- 메인 페이지에서 만든 공통 컴포넌트 재사용 -->
    <LocationSection />
  </div>

  <div class="pb-24 px-5">
    <ContactForm client:visible />
  </div>
</BaseLayout>
